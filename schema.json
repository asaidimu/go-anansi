{
  "version": "1.0.0",
  "name": "Schema",
  "description": "Meta-schema defining the structure of schema definitions",
  "fields": {
    "constraints": {
      "name": "constraints",
      "description": "Map of constraint definitions",
      "type": "record",
      "schema": { "id": "Constraint" }
    },
    "schemas": {
      "name": "schemas",
      "description": "Map of nested schema definitions",
      "type": "record",
      "schema": { "id": "NestedSchema" }
    },
    "name": {
      "name": "name",
      "description": "The name of the schema",
      "required": true,
      "type": "string"
    },
    "description": {
      "name": "description",
      "description": "Optional description of the schema",
      "type": "string"
    },
    "version": {
      "name": "version",
      "description": "Schema version",
      "required": true,
      "type": "string"
    },
    "metadata": {
      "name": "metadata",
      "description": "Arbitrary metadata as key-value pairs",
      "type": "record"
    },
    "fields": {
      "name": "fields",
      "description": "Map of field definitions",
      "type": "record",
      "schema": { "id": "Field" }
    },
    "indexes": {
      "name": "indexes",
      "description": "Map of index definitions",
      "type": "record",
      "schema": { "id": "Index" }
    }
  },
  "schemas": {

    "IndexCondition": {
      "name": "IndexCondition",
      "description": "A single condition for a partial index",
      "fields": {
        "field": {
          "name": "field",
          "description": "The field to check",
          "required": true,
          "type": "string"
        },
        "value": {
          "name": "value",
          "description": "The value to compare against",
          "required": true,
          "type": "unknown"
        },
        "operator": {
          "name": "operator",
          "description": "Comparison operator",
          "required": true,
          "type": "enum",
          "schema": { "id": "ComparisonOperatorEnum" }
        }
      }
    },
    "ConstraintUnion": { "name": "ConstraintUnion", "type": "union" },
    "IndexConditionGroup": {
      "name": "IndexConditionGroup",
      "description": "A group of conditions combined with a logical operator",
      "fields": {
        "operator": {
          "name": "operator",
          "description": "Logical operator (AND, OR, NOT)",
          "required": true,
          "type": "enum",
          "schema": { "id": "LogicalOperatorEnum" }
        },
        "conditions": {
          "name": "conditions",
          "description": "Array of conditions (each can be IndexCondition or IndexConditionGroup)",
          "required": true,
          "type": "array",
          "schema": { "id": "IndexConditionUnion" }
        }
      }
    },
    "Constraint": { "name": "Constraint", "type": "composite" },
    "ConstraintMetadata": {
      "name": "ConstraintMetadata",
      "description": "Metadata fields present in all constraints",
      "fields": {
        "name": {
          "name": "name",
          "description": "The name of the constraint",
          "required": true,
          "type": "string"
        },
        "description": {
          "name": "description",
          "description": "Optional description",
          "type": "string"
        }
      }
    },
    "IndexTypeEnum": {
      "name": "IndexTypeEnum",
      "type": "string",
      "values": ["normal", "unique", "primary", "spatial", "fulltext"]
    },
    "LogicalOperatorEnum": {
      "name": "LogicalOperatorEnum",
      "type": "string",
      "values": ["and", "or", "not", "nor", "xor", "nand", "xnor"]
    },
    "IndexOrderEnum": {
      "name": "IndexOrderEnum",
      "type": "string",
      "values": ["asc", "desc"]
    },
    "NestedSchema": {
      "name": "NestedSchema",
      "description": "Defines a nested schema - uses BaseSchema fields for objects, FieldProperties for array/enum elements",
      "fields": {
        "constraints": {
          "name": "constraints",
          "description": "Map of constraint definitions (for object types only)",
          "type": "record",
          "schema": { "id": "Constraint" }
        },
        "schema": {
          "name": "schema",
          "description": "FieldSchema reference (for complex array/set element types only)",
          "type": "union",
          "schema": [
            { "id": "FieldSchema" },
            { "id": "FieldSchemaArray" }
          ]
        },
        "name": {
          "name": "name",
          "description": "The name of the nested schema",
          "required": true,
          "type": "string"
        },
        "description": {
          "name": "description",
          "description": "Optional description",
          "type": "string"
        },
        "concrete": {
          "name": "concrete",
          "description": "Whether this schema should map to a physical collection",
          "type": "boolean"
        },
        "indexes": {
          "name": "indexes",
          "description": "Map of index definitions (for object types only)",
          "type": "record",
          "schema": { "id": "Index" }
        },
        "type": {
          "name": "type",
          "description": "The element type (for array/set/enum element types only)",
          "type": "enum",
          "schema": { "id": "FieldTypeEnum" }
        },
        "values": {
          "name": "values",
          "description": "Allowed values (for enum element types only)",
          "type": "array",
          "schema": { "type": "unknown" }
        },
        "metadata": {
          "name": "metadata",
          "description": "Arbitrary metadata (for object types only)",
          "type": "record"
        },
        "default": {
          "name": "default",
          "description": "Default value (for array/set/enum element types only)",
          "type": "unknown"
        },
        "fields": {
          "name": "fields",
          "description": "Map of field definitions (for object types only)",
          "type": "record",
          "schema": { "id": "Field" }
        }
      }
    },
    "Index": {
      "name": "Index",
      "description": "Defines an index for querying",
      "fields": {
        "name": {
          "name": "name",
          "description": "The name of the index",
          "required": true,
          "type": "string"
        },
        "description": {
          "name": "description",
          "description": "Optional description",
          "type": "string"
        },
        "unique": {
          "name": "unique",
          "description": "Whether the index enforces uniqueness",
          "type": "boolean"
        },
        "type": {
          "name": "type",
          "description": "The type of index",
          "required": true,
          "type": "enum",
          "schema": { "id": "IndexTypeEnum" }
        },
        "fields": {
          "name": "fields",
          "description": "Fields included in the index",
          "required": true,
          "type": "array",
          "schema": { "type": "string" }
        },
        "order": {
          "name": "order",
          "description": "Sort order",
          "type": "enum",
          "schema": { "id": "IndexOrderEnum" }
        },
        "condition": {
          "name": "condition",
          "description": "Optional condition for partial indexes",
          "type": "union",
          "schema": [
            { "id": "IndexCondition" },
            { "id": "IndexConditionGroup" }
          ]
        }
      }
    },
    "IndexConditionUnion": { "name": "IndexConditionUnion", "type": "union" },
    "FieldSchemaArray": { "name": "FieldSchemaArray", "type": "array" },
    "FieldSchema": {
      "name": "FieldSchema",
      "description": "Either a reference to a named schema or an inline type definition. The two shapes are mutually exclusive.",
      "type": "union",
      "schema": [
        { "id": "FieldSchemaRef" },
        { "id": "FieldSchemaInline" }
      ]
    },
    "FieldSchemaRef": {
      "name": "FieldSchemaRef",
      "description": "A reference to a named nested schema, with optional index and constraint augmentation",
      "fields": {
        "id": {
          "name": "id",
          "description": "The ID of the referenced schema",
          "required": true,
          "type": "string"
        },
        "indexes": {
          "name": "indexes",
          "description": "Additional indexes for this reference",
          "type": "record",
          "schema": { "id": "Index" }
        },
        "constraints": {
          "name": "constraints",
          "description": "Additional constraints for this reference",
          "type": "record",
          "schema": { "id": "Constraint" }
        }
      }
    },
    "FieldSchemaInline": {
      "name": "FieldSchemaInline",
      "description": "An inline type definition for simple or enum types that do not warrant a named schema",
      "fields": {
        "type": {
          "name": "type",
          "description": "The inline type",
          "required": true,
          "type": "enum",
          "schema": { "id": "FieldTypeEnum" }
        },
        "values": {
          "name": "values",
          "description": "Allowed values, for enum types only",
          "type": "array",
          "schema": { "type": "unknown" }
        }
      }
    },
    "ComparisonOperatorEnum": {
      "name": "ComparisonOperatorEnum",
      "type": "string",
      "values": [
        "eq",
        "neq",
        "lt",
        "lte",
        "gt",
        "gte",
        "in",
        "nin",
        "contains",
        "ncontains",
        "exists",
        "nexists"
      ]
    },
    "Field": {
      "name": "Field",
      "description": "Defines a field within a schema",
      "fields": {
        "required": {
          "name": "required",
          "description": "Whether the field is required",
          "type": "boolean"
        },
        "deprecated": {
          "name": "deprecated",
          "description": "Whether the field is deprecated",
          "type": "boolean"
        },
        "unique": {
          "name": "unique",
          "description": "Whether the field value must be unique",
          "type": "boolean"
        },
        "type": {
          "name": "type",
          "description": "The type of the field",
          "required": true,
          "type": "enum",
          "schema": { "id": "FieldTypeEnum" }
        },
        "schema": {
          "name": "schema",
          "description": "FieldSchema for complex types — single FieldSchema or array for unions/composites",
          "type": "union",
          "schema": [
            { "id": "FieldSchema" },
            { "id": "FieldSchemaArray" }
          ]
        },
        "name": {
          "name": "name",
          "description": "The name of the field",
          "required": true,
          "type": "string"
        },
        "description": {
          "name": "description",
          "description": "Optional description of the field",
          "type": "string"
        },
        "default": {
          "name": "default",
          "description": "Default value for the field",
          "type": "unknown"
        }
      }
    },
    "ConstraintRule": {
      "name": "ConstraintRule",
      "description": "A single validation rule with a predicate",
      "fields": {
        "parameters": {
          "name": "parameters",
          "description": "Parameters for the predicate",
          "type": "unknown"
        },
        "fields": {
          "name": "fields",
          "description": "Fields this rule applies to",
          "type": "array",
          "schema": { "type": "string" }
        },
        "predicate": {
          "name": "predicate",
          "description": "The predicate function name",
          "required": true,
          "type": "string"
        }
      }
    },
    "ConstraintGroup": {
      "name": "ConstraintGroup",
      "description": "A group of constraints combined with a logical operator",
      "fields": {
        "operator": {
          "name": "operator",
          "description": "Logical operator (AND, OR, NOT)",
          "required": true,
          "type": "enum",
          "schema": { "id": "LogicalOperatorEnum" }
        },
        "rules": {
          "name": "rules",
          "description": "Array of constraint rules or groups",
          "required": true,
          "type": "array",
          "schema": { "id": "ConstraintUnion" }
        }
      }
    },
    "FieldTypeEnum": {
      "name": "FieldTypeEnum",
      "type": "string",
      "values": [
        "unknown",
        "string",
        "number",
        "integer",
        "decimal",
        "boolean",
        "array",
        "set",
        "enum",
        "object",
        "record",
        "union",
        "composite",
        "geometry"
      ]
    }
  }
}
